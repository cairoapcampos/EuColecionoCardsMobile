<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="4dp"
    android:background="@color/site_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">


            <FrameLayout
                android:layout_width="150dp"
                android:layout_height="200dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="16dp">
                <ImageView
                    android:id="@+id/ivImagem"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_launcher_foreground"
                    android:background="@drawable/cardview_image_bg"
                    android:contentDescription="@string/item_carta_image_description" />
                <ImageView
                    android:id="@+id/ivFavorito"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:src="@drawable/ic_favorite_border"
                    android:contentDescription="@string/item_carta_favorite_description"
                    android:background="@android:color/transparent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="0dp"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="2dp"
                android:clipToOutline="true"
                android:backgroundTint="@android:color/white"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:layout_marginEnd="4dp"
                android:layout_marginStart="0dp"
                android:backgroundTintMode="src_in"
                android:outlineProvider="background">

                <TextView
                    android:id="@+id/tvNome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_carta_name_placeholder"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="@color/site_dark_text"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvDescricao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_carta_description_placeholder"
                    android:textColor="#666"
                    android:textSize="15sp"
                    android:layout_marginBottom="6dp"
                    android:maxLines="4"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvTipo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_carta_type_placeholder"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvRaridade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_carta_rarity_placeholder"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginBottom="2dp" />
                <TextView
                    android:id="@+id/tvColecao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_carta_collection_placeholder"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginBottom="2dp" />
                <TextView
                    android:id="@+id/tvAno"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_carta_year_placeholder"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvQualidade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_carta_quality_placeholder"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvEstoque"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_carta_stock_placeholder"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvPreco"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_carta_price_placeholder"
                    android:textColor="@color/site_yellow"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemover"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="@string/item_carta_remove"
                android:textAllCaps="false"
                android:textColor="@color/site_button_text"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/site_dark"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/tvQuantidade"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="@string/item_carta_quantity_zero"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/site_dark_text" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdicionar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="@string/item_carta_add"
                android:textAllCaps="false"
                android:textColor="@color/site_button_text"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/site_dark"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
